    "nodemailer": "^8.0.5",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.30",
    "@types/nodemailer": "^8.0.0",
    "kill-port": "^2.0.1",
